#!/usr/bin/env python3
"""GitHub-backed catalog search for SKILL.md files in trusted repositories.

Reads ``~/.claude/skill-repos.json`` for the user's trusted-repos list, falling
back to the built-in default when the file is absent. Wraps ``gh`` for search
and content fetch; requires ``gh auth login`` (or ``GITHUB_TOKEN``).

Run from anywhere. Requires the Python stdlib and the ``gh`` CLI on PATH.
Shipped on PATH by the cc-project-management-plugin as ``skill-catalog``.

Usage:
  skill-catalog search "<query>"   # JSON array of hits to stdout
  skill-catalog get <id>           # raw SKILL.md body to stdout
                                   # id format: <owner>/<repo>:<path>

Exit codes:
  0  success
  2  ``gh`` missing or unauthenticated
  3  no hits (search) or skill not found (get)
  1  any other error
"""

from __future__ import annotations

import json
import shutil
import subprocess
import sys
from pathlib import Path

DEFAULT_REPOS = ["anthropics/skills"]
CONFIG_PATH = Path.home() / ".claude" / "skill-repos.json"
SEARCH_LIMIT_PER_REPO = 10


def fail(msg: str, code: int = 1) -> "None":
    print(f"skill-catalog: {msg}", file=sys.stderr)
    sys.exit(code)


def check_gh() -> None:
    if not shutil.which("gh"):
        fail("`gh` CLI not installed — see https://cli.github.com/", code=2)
    r = subprocess.run(["gh", "auth", "status"], capture_output=True, text=True)
    if r.returncode != 0:
        fail(
            "`gh` is not authenticated — run `gh auth login` or set GITHUB_TOKEN",
            code=2,
        )


def load_repos() -> list[str]:
    if not CONFIG_PATH.exists():
        return list(DEFAULT_REPOS)
    try:
        data = json.loads(CONFIG_PATH.read_text())
    except json.JSONDecodeError as e:
        fail(f"invalid JSON in {CONFIG_PATH}: {e}")
    if not isinstance(data, list) or not all(isinstance(x, str) and x for x in data):
        fail(
            f"{CONFIG_PATH} must be a JSON array of non-empty strings, "
            f'e.g. ["anthropics/skills", "myorg/my-skills"]'
        )
    return data


def gh_json(args: list[str]) -> object:
    r = subprocess.run(["gh", *args], capture_output=True, text=True)
    if r.returncode != 0:
        fail(f"gh command failed: gh {' '.join(args)}\n{r.stderr.strip()}")
    return json.loads(r.stdout) if r.stdout.strip() else []


def search(query: str) -> list[dict]:
    hits: list[dict] = []
    seen: set[str] = set()
    for entry in load_repos():
        scope = ["--repo", entry] if "/" in entry else ["--owner", entry]
        results = gh_json(
            [
                "search",
                "code",
                query,
                "--filename",
                "SKILL.md",
                *scope,
                "--limit",
                str(SEARCH_LIMIT_PER_REPO),
                "--json",
                "repository,path,textMatches",
            ]
        )
        for item in results or []:
            repo_full = item["repository"]["nameWithOwner"]
            path = item["path"]
            sid = f"{repo_full}:{path}"
            if sid in seen:
                continue
            seen.add(sid)
            tm = item.get("textMatches") or []
            snippet = tm[0].get("fragment", "") if tm else ""
            hits.append(
                {"id": sid, "repo": repo_full, "path": path, "snippet": snippet}
            )
    return hits


def cmd_search(query: str) -> None:
    check_gh()
    hits = search(query)
    print(json.dumps(hits, indent=2))
    if not hits:
        sys.exit(3)


def cmd_get(skill_id: str) -> None:
    check_gh()
    if ":" not in skill_id:
        fail("get requires id of the form <owner>/<repo>:<path>")
    repo, path = skill_id.split(":", 1)
    if "/" not in repo:
        fail("repo must be <owner>/<repo>")
    r = subprocess.run(
        [
            "gh",
            "api",
            f"repos/{repo}/contents/{path}",
            "-H",
            "Accept: application/vnd.github.raw",
        ],
        capture_output=True,
        text=True,
    )
    if r.returncode != 0:
        if "404" in r.stderr or "Not Found" in r.stderr:
            fail(f"skill not found: {skill_id}", code=3)
        fail(f"gh api failed: {r.stderr.strip()}")
    sys.stdout.write(r.stdout)


def main() -> None:
    if len(sys.argv) < 2:
        sys.exit("usage: skill-catalog {search <query>|get <id>}")
    cmd = sys.argv[1]
    if cmd == "search":
        if len(sys.argv) != 3:
            sys.exit("usage: skill-catalog search <query>")
        cmd_search(sys.argv[2])
    elif cmd == "get":
        if len(sys.argv) != 3:
            sys.exit("usage: skill-catalog get <id>")
        cmd_get(sys.argv[2])
    else:
        sys.exit(f"unknown command: {cmd}")


if __name__ == "__main__":
    main()
